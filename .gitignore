# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# migration artifacts — content is already copied into content/ and public/images/.
# Keeping only the extraction scripts in git; the raw HTML, intermediate MDX, and
# duplicated images are one-shot and regeneratable.
/migration/raw-html/
/migration/blog/
/migration/images/
/migration/podcasts/
/migration/vacancies/
/migration/static/
/migration/*.json
/migration/**/__pycache__/
